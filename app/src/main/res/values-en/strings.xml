    <!-- Privacy Policy Screen -->
    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_back">Back</string>
    <string name="privacy_header">SeniorAssistant App Privacy Policy</string>
    <string name="privacy_section1_title">1. Personal Data Administrator</string>
    <string name="privacy_section1_content">The administrator of your personal data is Dominik Szymczak and Filip Zawisza. We process your data with the utmost care, in accordance with the provisions of Regulation (EU) 2016/679 of the European Parliament and of the Council (GDPR).</string>
    <string name="privacy_section2_title">2. What data do we collect?</string>
    <string name="privacy_section2_content">When using the Application, we may collect the following data:\n• Data provided during registration: first name, last name, email address, phone number.\n• Profile data: selected role (Senior or Volunteer), preferences regarding reminders.\n• Technical and system data: device information, error logs.\n• Location data: (optional) collected only with your consent, to match help requests to the nearest volunteers.\n• Content entered in the application: content of help requests, names of reminders (e.g. about medications) and queries directed to the AI Assistant.</string>
    <string name="privacy_section3_title">3. Purpose and legal basis for processing</string>
    <string name="privacy_section3_content">Your data is processed for the following purposes:\n• Providing services within the Application, including enabling contact between Seniors and Volunteers (Art. 6(1)(b) GDPR).\n• Personalizing Application features, such as reminders (Art. 6(1)(b) GDPR).\n• Ensuring security, fraud prevention and technical support (Art. 6(1)(f) GDPR).</string>
    <string name="privacy_section4_title">4. Data sharing and AI Assistant</string>
    <string name="privacy_section4_content">• To enable the provision of help, basic contact and profile data of the Senior are visible to the Volunteer undertaking the request (and vice versa).\n• When using the AI Assistant function, entered queries may be processed by external artificial intelligence service providers (e.g. OpenAI, Google), depending on the configured API key, solely for the purpose of generating a response.\n• We do not sell your personal data to third parties.</string>
    <string name="privacy_section5_title">5. User Rights (GDPR)</string>
    <string name="privacy_section5_content">Under the law, you have the right to:\n• Access your data and receive a copy of it.\n• Rectify (correct) incorrect data.\n• Delete data (\"right to be forgotten\") by deleting the account in the Application settings.\n• Restrict processing and object.</string>
    <string name="privacy_section6_title">6. Data security</string>
    <string name="privacy_section6_content">We use appropriate technical and organizational measures to protect your data against unauthorized access, loss or destruction. However, please remember that no data transmission over the Internet is 100% secure.</string>
    <string name="privacy_section7_title">7. Contact</string>
    <string name="privacy_section7_content">In case of questions regarding privacy, editing or deleting data, please contact us at: kontakt@seniorassistant.pl.</string>

